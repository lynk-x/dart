# Lynk-X PWA Environment Configuration
# Use these keys with the --dart-define flag during build:
# flutter build web --release --dart-define=SUPABASE_URL=... --dart-define=SUPABASE_ANON_KEY=...

# Required for Supabase integration
SUPABASE_URL=your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-pub-key

# Optional: Sentry error reporting
SENTRY_DSN=https://...

# Performance/Debug
ENABLE_CRASH_REPORTING=true
